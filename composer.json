{
    "name": "nawasara/core",
    "description": "Core package for Nawasara: authentication via Laravel Fortify, role/permission via Spatie, branding settings, and shared helpers.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nawasara",
        "laravel",
        "fortify",
        "authentication",
        "rbac",
        "spatie-permission",
        "branding"
    ],
    "authors": [
        {
            "name": "Pringgo J. Saputro",
            "email": "odyinggo@gmail.com",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/nawasara/core/issues",
        "source": "https://github.com/nawasara/core"
    },
    "autoload": {
        "psr-4": {
            "Nawasara\\Core\\": "src/"
        },
        "files": [
            "src/Helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Nawasara\\Core\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "nawasara/ui": "*",
        "nawasara/vault": "*",
        "spatie/laravel-permission": "^6.0",
        "livewire/livewire": "^3.0",
        "laravel/fortify": "^1.0",
        "laravel/socialite": "^5.0",
        "socialiteproviders/keycloak": "^5.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Core\\CoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
