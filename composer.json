{
    "name": "nawasara/core",
    "description": "Auth, user management, and role/permission for Nawasara superapp",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Nawasara\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nawasara\\Core\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^12.0",
        "nawasara/ui": "*",
        "spatie/laravel-permission": "^6.0",
        "livewire/livewire": "^3.0",
        "laravel/fortify": "^1.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Nawasara\\Core\\CoreServiceProvider"
            ]
        }
    }
}
